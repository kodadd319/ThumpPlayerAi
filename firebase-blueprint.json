{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile config, vehicle info, and audio/DSP synthesizer configurations",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "accentTheme": { "type": "string" },
        "lastLogin": { "type": "string" },
        "volume": { "type": "number" },
        "isMuted": { "type": "boolean" },
        "repeatMode": { "type": "string" },
        "shuffleMode": { "type": "boolean" },
        "subscriptionTier": { "type": "string" },
        "currentTrackId": { "type": "string" },
        "selectedPresetName": { "type": "string" },
        "isMaxBass": { "type": "boolean" },
        "vehicleInfo": { "type": "object" },
        "dspSettings": { "type": "object" },
        "updatedAt": { "type": "string" }
      },
      "required": ["uid"]
    },
    "Track": {
      "title": "Track",
      "description": "Music track index reference pointing to persistent Cloud Storage assets",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "artist": { "type": "string" },
        "album": { "type": "string" },
        "genre": { "type": "string" },
        "url": { "type": "string" },
        "storagePath": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["uid", "name", "url"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile settings document keyed by user unique ID"
    },
    "/tracks/{trackId}": {
      "schema": "Track",
      "description": "Uploader tracks directory referenced to query matching uid"
    }
  }
}
